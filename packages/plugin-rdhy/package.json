{
  "name": "@marketlum/plugin-rdhy",
  "version": "0.3.0",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared/schemas.d.ts",
      "default": "./dist/shared/schemas.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "default": "./dist/web/index.js"
    },
    "./web/messages": {
      "types": "./dist/web/messages.d.ts",
      "default": "./dist/web/messages.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@marketlum/core": "workspace:*",
    "@marketlum/shared": "workspace:*",
    "@marketlum/ui": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "d3": "^7.9.0",
    "lucide-react": "^0.400.0",
    "next-intl": "^4.8.2",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.5.0"
  }
}
